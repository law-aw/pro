# edge = Raspberry Pi (local kiosk + sync client)
# hub  = cloud/remote server (admin from home, Pi pulls updates)
ROLE=edge

PORT=3000
HOST=0.0.0.0
SESSION_SECRET=change-this-to-a-long-random-string

# Path for SQLite DB and uploaded media (created automatically)
DATA_DIR=./data

# Edge only: pull updates from hub when internet is available
SYNC_HUB_URL=
SYNC_API_KEY=
SYNC_INTERVAL_MS=120000

# Hub only: API key Pi uses to authenticate sync pulls
# Must match SYNC_API_KEY on the Pi
